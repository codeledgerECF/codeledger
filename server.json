{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codeledgerECF/codeledger",
  "description": "Deterministic context selection for AI coding agents. Local memory that compounds across sessions.",
  "repository": {
    "url": "https://github.com/codeledgerECF/codeledger",
    "source": "github"
  },
  "version": "0.10.7",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codeledger/cli",
      "version": "0.10.7",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        },
        {
          "type": "positional",
          "value": "start"
        }
      ]
    }
  ]
}
